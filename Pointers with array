#include <iostream>
using namespace std;

int getsum(int *arr, int n){
    int sum = 0;
    for(int i=0; i<n; i++){
        sum += arr[i];
    }
    return sum;
}

void update (int *p){           //passsed a copy so original value wont change.
    p = p+1;
}
int main() {

    int value = 5;
    int *p = &value;
    
    cout<<"before : " << p << endl;
    update(p);
    cout<<"after : " << p << endl;
    
    int arr[5] = {1,2,3,4,5};
    cout<< "sum is : " <<getsum(arr,5) <<endl;
    
    return 0;
}
