#include <iostream>
#include <array>            //for STL
using namespace std;
int main() {
    int basic[3] = {1,2,3}; //normal implementation 
    array<int,4> a = {1,2,3,4}; //using STL
    
    int size = a.size();        //saves size
    for(int i = 0; i<size; i++){
        cout<<a[i]<<" ";
    }
    
    cout<<"element at index 2: "<<a.at(2)<<endl; //returns element at that index
    cout<<"Empty or not: "<<a.empty()<<endl; //returns bool
    cout<<"1st element: "<<a.front()<<endl; //returns 1st element
    cout<<"last element: "<<a.back()<<endl; //returns last element
}
