#include <iostream>
#include <queue>            //first element always greatest and priority queue relates to max heap
using namespace std;
int main() {

    priority_queue<int> maxi;   //max heap
    
    priority_queue<int,vector<int>, greater<int> > mini;    //min heap
    
    maxi.push(1);
    maxi.push(3);
    maxi.push(2);
    maxi.push(0);
    
    int maxi_size = maxi.size();
    for(int i =0; i<maxi_size; i++){
        cout<<maxi.top()<<" ";
        maxi.pop();
    }cout<<endl;
    
    mini.push(5);
    mini.push(1);
    mini.push(0);
    mini.push(4);
    mini.push(3);
    int mini_size = mini.size();
    for(int i =0; i<mini_size; i++){
        cout<<mini.top()<<" ";
        mini.pop();
    }cout<<endl;
    
}
