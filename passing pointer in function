#include <iostream>
using namespace std;

void update (int *p){           //passed a copy so original value wont change.
    p = p+1;
}
int main() {

    int value = 5;
    int *p = &value;
    
    cout<<"before : " << p << endl;
    update(p);
    cout<<"after : " << p << endl;
    
    return 0;
}
