#include <iostream>
using namespace std;

void update (int *p){           //passed a copy so original value wont change but if we do operation on stored value in that then it will update  
    p = p+1;
    cout<< "inside: " << p << endl; 
    *p = *p+1;
}
int main() {

    int value = 5;
    int *p = &value;
    cout<<"before : " << *p << endl;
    cout<<"before : " << p << endl;
    update(p);
    cout<<"after : " << p << endl;
    cout<<"after : " << *p << endl;
    
    return 0;
}
