//same number of rows and columns

#include <iostream>
using namespace std;

int main() {
int n;
cout<<"enter size of 2D array: ";
cin>>n;
cout<<endl;

int **arr = new int*[n];

//creating 2D array
for(int i=0; i<n; i++){
    arr[i] = new int[n];
}

//taking inputs
cout << "give inputs";
for(int i=0; i<n; i++){
    for(int j=0; j<n; j++){
        cin >> arr[i][j];
    }
}

//showing output
for(int i=0; i<n; i++){
    for(int j=0; j<n; j++){
        cout<< arr[i][j] << " ";
    }cout<<endl;
}

return 0;
}

