#include <iostream>
using namespace std;
int getSum(int *arr, int n){
    int sum = 0;
    for(int i = 0; i<n; i++){
        sum += arr[i];
    }
    return sum;
}

int main() {
int n;
cout<< "enter size of array: ";
cin>>n;

int *arr = new int[n];

for(int i = 0; i<n; i++){
    cout<<"enter values of element "<< i <<":";
    cin>>arr[i];
    
}

cout<<"addition of array is: ";
int result = getSum(arr, n);
cout<<result;
    
    
}
